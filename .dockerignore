# ── Ignorar no build Docker ────────────────────────────────

# Cache Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Ambientes virtuais
venv/
.venv/
env/

# Modelos de voz (pesados, não são usados no servidor web)
modelos/

# GUI (não roda no servidor)
gui/

# Dados locais (montados via volume no docker-compose)
perfis.json
turmas.json
avisos.json
atividades.json

# Git
.git/
.gitignore

# Outros
*.md
.DS_Store
*.log
